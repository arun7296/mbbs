generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Phase {
  PHASE_1
  PHASE_2
  PHASE_3_PART1
  PHASE_3_PART2
}

enum CompetencyLevel {
  KNOWS
  KNOWS_HOW
  SHOWS_HOW
  DOES
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTI
  CASE_BASED_MCQ
  ASSERTION_REASON
  MATCH_THE_FOLLOWING
  SHORT_ANSWER
  LONG_ANSWER
  IMAGE_BASED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum ExamTag {
  NEXT_STEP1
  NEXT_STEP2
  NEET_PG
  UNIVERSITY
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum LearningMode {
  LEARN
  PRACTICE
  REVISE
  TEST
  CLINICAL_SIM
}

enum CaseStageType {
  HISTORY
  EXAMINATION
  INVESTIGATION
  DIAGNOSIS
  TREATMENT
  FOLLOWUP
}

// ─── Identity ────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  phone              String?   @unique
  avatarUrl          String?
  passwordHash       String?
  currentPhase       Phase     @default(PHASE_1)
  mbbsStartYear      Int?
  collegeId          String?
  dailyStudyHours    Float     @default(6.0)
  targetExams        ExamTag[]
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  college       College?        @relation(fields: [collegeId], references: [id])
  progress      UserProgress[]
  quizzes       Quiz[]
  caseAttempts  CaseAttempt[]
  studyPlans    StudyPlan[]
  streak        UserStreak?
  abilities     SubjectAbility[]
  accounts      Account[]
  sessions      Session[]
}

model College {
  id      String  @id @default(cuid())
  name    String
  nmcCode String? @unique
  state   String
  users   User[]
}

// ─── NextAuth models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Curriculum ──────────────────────────────────────────────────────

model Subject {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  phase       Phase
  totalHours  Int
  description String?
  iconUrl     String?
  sortOrder   Int     @default(0)

  modules      Module[]
  competencies NmcCompetency[]
  questions    Question[]
  abilities    SubjectAbility[]
}

model Module {
  id             String  @id @default(cuid())
  subjectId      String
  name           String
  code           String  @unique
  description    String?
  sortOrder      Int     @default(0)
  estimatedHours Float   @default(0)

  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics  Topic[]
  lessons Lesson[]
}

model Topic {
  id              String  @id @default(cuid())
  moduleId        String
  name            String
  code            String  @unique
  nmcCompetencyId String?
  sortOrder       Int     @default(0)

  module     Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  competency NmcCompetency? @relation(fields: [nmcCompetencyId], references: [id])
  lessons    Lesson[]
  questions  Question[]
  progress   UserProgress[]
}

model NmcCompetency {
  id             String          @id @default(cuid())
  code           String          @unique
  description    String
  subjectId      String
  domain         String
  level          CompetencyLevel
  phase          Phase
  isAetcom       Boolean         @default(false)
  aetcomModuleId String?

  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  aetcomModule AetcomModule? @relation(fields: [aetcomModuleId], references: [id])
  topics       Topic[]
  questions    Question[]
}

model AetcomModule {
  id           String @id @default(cuid())
  moduleNumber Int
  title        String
  phase        Phase
  description  String

  competencies NmcCompetency[]
}

// ─── Content ─────────────────────────────────────────────────────────

model Lesson {
  id               String        @id @default(cuid())
  topicId          String
  moduleId         String
  title            String
  slug             String        @unique
  layer            Int           // 1=Foundation, 2=Mechanism, 3=Clinical, 4=Exam, 5=ActiveRecall
  contentMd        String
  summary          String?
  mnemonics        Json?         // [{text, explanation, tags}]
  keyPoints        Json?         // string[]
  textbookRefs     Json?         // [{book, chapter, page, edition}]
  diagramUrls      Json?         // string[]
  videoUrl         String?
  estimatedMinutes Int           @default(20)
  status           ContentStatus @default(DRAFT)
  version          Int           @default(1)
  examTags         ExamTag[]
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?

  topic     Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  module    Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  revisions LessonRevision[]
  progress  UserProgress[]
  videos    VideoResource[]
  visuals   VisualResource[]

  @@unique([topicId, layer])
}

model LessonRevision {
  id         String   @id @default(cuid())
  lessonId   String
  version    Int
  contentMd  String
  changedBy  String
  changeNote String?
  createdAt  DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ─── Video Resources ─────────────────────────────────────────────────

model VideoResource {
  id              String   @id @default(cuid())
  lessonId        String
  youtubeVideoId  String
  youtubeUrl      String
  title           String
  channelName     String
  channelUrl      String?
  durationSeconds Int
  description     String?
  startTimestamp  Int?
  endTimestamp    Int?
  quality         String   @default("RECOMMENDED")
  language        String   @default("en")
  sortOrder       Int      @default(0)
  thumbnailUrl    String?
  viewCount       Int?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@unique([lessonId, youtubeVideoId])
}

// ─── Visual Resources ───────────────────────────────────────────────

model VisualResource {
  id            String   @id @default(cuid())
  lessonId      String
  type          String   // SVG_DIAGRAM | ANIMATED | IMAGE | FLOWCHART | COMPARISON_TABLE
  title         String
  description   String?

  // For SVG/Animated: component name to render
  componentName String?  // e.g., "CardiacCycleDiagram", "BrachialPlexusSVG"

  // For external images
  imageUrl      String?
  imageAlt      String?
  attribution   String?
  license       String?  // PUBLIC_DOMAIN | CC_BY | CC_BY_SA | CC_BY_NC

  // For all types
  category      String   @default("ANATOMY")
  tags          String[]
  sortOrder     Int      @default(0)

  // Inline SVG content (for simple diagrams stored directly)
  svgContent    String?

  // Annotation data (labels, hotspots on images)
  annotations   Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([category])
}

// ─── Assessment ──────────────────────────────────────────────────────

model Question {
  id                String       @id @default(cuid())
  type              QuestionType
  subjectId         String
  topicId           String?
  competencyId      String?
  stem              String
  options           Json?        // [{id, text, isCorrect, explanation}]
  correctAnswer     String?
  explanation       String
  difficulty        Difficulty   @default(MEDIUM)
  examTags          ExamTag[]
  bloomsLevel       String       @default("Recall") // Recall, Analysis, ProblemSolving
  discriminationIdx Float?       // IRT a
  difficultyParam   Float?       // IRT b
  guessingParam     Float?       // IRT c
  imageUrls         Json?
  clinicalVignette  String?
  textbookRefs      Json?
  status            ContentStatus @default(PUBLISHED)
  usageCount        Int          @default(0)
  avgCorrectRate    Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  subject      Subject        @relation(fields: [subjectId], references: [id])
  topic        Topic?         @relation(fields: [topicId], references: [id])
  competency   NmcCompetency? @relation(fields: [competencyId], references: [id])
  quizQuestions QuizQuestion[]
}

model Quiz {
  id           String    @id @default(cuid())
  userId       String
  title        String
  mode         String    // practice, timed_test, mock_exam, adaptive
  subjectIds   String[]
  topicIds     String[]
  totalQs      Int
  timeLimitMin Int?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  score        Float?
  percentile   Float?
  abilityEst   Float?

  user      User           @relation(fields: [userId], references: [id])
  questions QuizQuestion[]
}

model QuizQuestion {
  id              String   @id @default(cuid())
  quizId          String
  questionId      String
  sequenceNum     Int
  selectedAnswer  String?
  isCorrect       Boolean?
  timeSpentSec    Int?
  markedForReview Boolean  @default(false)
  abilityAtPoint  Float?

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])
}

model MockExam {
  id            String    @id @default(cuid())
  title         String
  examTag       ExamTag
  totalQs       Int
  timeLimitMin  Int
  sections      Json      // [{name, subjectIds, questionCount}]
  isPublished   Boolean   @default(false)
  availableFrom DateTime?
  availableTo   DateTime?
  createdAt     DateTime  @default(now())
}

// ─── Clinical Simulation ─────────────────────────────────────────────

model ClinicalCase {
  id                  String        @id @default(cuid())
  title               String
  presentingComplaint String
  subjectIds          String[]
  topicIds            String[]
  competencyIds       String[]
  difficulty          Difficulty    @default(MEDIUM)
  caseType            String        // OPD, Emergency, Ward, ICU
  patientProfile      Json          // {age, sex, occupation, history}
  examTags            ExamTag[]
  estimatedMinutes    Int           @default(30)
  status              ContentStatus @default(DRAFT)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  stages   CaseStage[]
  attempts CaseAttempt[]
}

model CaseStage {
  id               String        @id @default(cuid())
  caseId           String
  stage            CaseStageType
  stageOrder       Int
  prompt           String
  availableActions Json          // [{id, text, type, isOptimal, findings, scoreDelta}]
  findings         Json?
  timeoutSec       Int?

  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, stageOrder])
}

model CaseAttempt {
  id          String    @id @default(cuid())
  userId      String
  caseId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  decisions   Json      // [{stageId, actionChosen, timeSpentSec, scoreAwarded}]
  totalScore  Float?
  maxScore    Float?
  feedback    String?

  user         User         @relation(fields: [userId], references: [id])
  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id])
}

model OsceStation {
  id             String        @id @default(cuid())
  title          String
  type           String        // Observed, Unobserved
  domain         String        // Cognitive, Psychomotor, Affective
  subjectId      String
  competencyIds  String[]
  scenario       String
  checklistItems Json          // [{id, description, domain, maxScore}]
  timeLimitMin   Int           @default(10)
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
}

// ─── Progress & Analytics ────────────────────────────────────────────

model UserProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String?
  topicId        String
  subjectId      String
  completionPct  Float     @default(0)
  lastAccessedAt DateTime  @default(now())
  timeSpentMin   Int       @default(0)
  masteryLevel   Float     @default(0)
  nextReviewAt   DateTime?
  easeFactor     Float     @default(2.5)
  interval       Int       @default(1)
  repetitions    Int       @default(0)
  updatedAt      DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])
  topic  Topic   @relation(fields: [topicId], references: [id])

  @@unique([userId, topicId])
}

model StudyPlan {
  id            String   @id @default(cuid())
  userId        String
  name          String
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean  @default(true)
  generatedByAi Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User           @relation(fields: [userId], references: [id])
  days StudyPlanDay[]
}

model StudyPlanDay {
  id           String   @id @default(cuid())
  planId       String
  date         DateTime
  tasks        Json     // [{topicId, lessonId, mode, durationMin, completed}]
  completedPct Float    @default(0)

  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, date])
}

model UserStreak {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime

  user User @relation(fields: [userId], references: [id])
}

model SubjectAbility {
  id         String   @id @default(cuid())
  userId     String
  subjectId  String
  theta      Float    @default(0)
  confidence Float    @default(0)
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
}
