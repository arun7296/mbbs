{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "../.seed-dist",
    "rootDir": "..",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "strict": false
  },
  "include": [
    "seeds/**/*.ts"
  ]
}
